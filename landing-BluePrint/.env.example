# ─────────────────────────────────────────────────────────
#  WMS Platform Landing — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  cp .env.example .env.local
# ─────────────────────────────────────────────────────────

# Server port (PM2 / Next.js)
PORT=3000

# ── Admin API ─────────────────────────────────────────────
# Used to protect GET /api/subscribe
# Generate a strong random string: openssl rand -hex 32
ADMIN_TOKEN=change_me_to_a_strong_secret_key

# ── Optional: Email notifications on new leads ─────────────
# Uncomment and fill in to receive email alerts when someone
# submits the demo request form.
#
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=noreply@wms-platform.ru
# SMTP_PASS=your_password_here
# NOTIFY_EMAIL=sales@wms-platform.ru
